# 🖥️ Ejemplo de Configuración - .env

# ==============================================
# SERVIDOR
# ==============================================
PORT=3000
NODE_ENV=development

# ==============================================
# BASE DE DATOS - PostgreSQL
# ==============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres_password_123
DB_NAME=brasa33_db

# ==============================================
# AUTENTICACIÓN JWT
# ==============================================
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long_here_2024

# ==============================================
# API CONFIGURATION
# ==============================================
API_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,https://frontend.brasa33.com

# ==============================================
# AUTH SERVICE (Centralizado en .NET)
# ==============================================
AUTH_SERVICE_URL=http://localhost:5000
AUTH_SERVICE_TIMEOUT=10000

# ==============================================
# LOGGING
# ==============================================
LOG_LEVEL=debug
LOG_FORMAT=json

# ==============================================
# RATE LIMITING
# ==============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==============================================
# CORS
# ==============================================
CORS_ENABLED=true
CORS_CREDENTIALS=true

# ==============================================
# SEGURIDAD
# ==============================================
HELMET_ENABLED=true
HTTPS_REDIRECT=false

# ==============================================
# REPORTES
# ==============================================
REPORTS_MAX_RECORDS=1000
REPORTS_DATE_FORMAT=YYYY-MM-DD
